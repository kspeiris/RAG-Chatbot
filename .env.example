OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
ANSWER_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3
LOCAL_LLM_TIMEOUT_SECONDS=120
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_STORAGE_PATH=.qdrant
COLLECTION_NAME=knowledge_base
STRICT_GROUNDED_MODE=true
MAX_CONTEXT_CHUNKS=6
RERANK_CANDIDATES=20
BM25_CANDIDATES=20
ADJACENT_CHUNK_WINDOW=1
GENERAL_DOC_MATCH_THRESHOLD=0.62
SQLITE_DB_NAME=csv_data.sqlite
MAX_SQL_RESULT_ROWS=25
ENABLE_CROSS_ENCODER_RERANKER=false
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
CHUNK_SIZE=750
CHUNK_OVERLAP=160
MIN_CHUNK_CHARS=180
EVALUATION_CASES_NAME=evaluation_cases.json
OCR_ENABLED=true
OCR_LANGUAGE=eng
OCR_MIN_TEXT_CHARS=80
OCR_ON_SHORT_PDF_PAGES=true
OCR_MAX_PDF_PAGES=30
